# Anthropic API key for the Footer "Ask AI Assistant" chat widget (/api/chat)
ANTHROPIC_API_KEY=

# Resend API key — used by the Contact form and the reservation confirmation email
RESEND_API_KEY=

# Optional overrides for the contact email route
CONTACT_TO_EMAIL=venuacha@whiteboard.cafe
CONTACT_FROM_EMAIL=Blackboard Cafe Website <onboarding@resend.dev>
# Owner inbox that receives new-inquiry notifications (falls back to CONTACT_TO_EMAIL)
CONTACT_OWNER_EMAIL=

# PostgreSQL connection string (Neon, Supabase, etc.) for reservations + inquiries (Prisma)
DATABASE_URL=

# NextAuth — protects /admin (reservations + inquiries dashboard)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Admin login credentials: plaintext email + bcrypt hash of the password
# Generate a hash with: npx bcryptjs-cli hash "yourpassword" (or any bcrypt tool)
# IMPORTANT: escape every $ as \$ below — Next.js interpolates unescaped $VAR
# patterns in .env files, which silently corrupts bcrypt hashes otherwise.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Twilio — SMS + WhatsApp reservation confirmations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Upstash Redis — contact form rate limiting (5 submissions/hour/IP)
# Skipped gracefully if unset. Create a free database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google reCAPTCHA v3 — contact form spam protection
# Skipped gracefully if unset. Register a site at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
